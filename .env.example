# Discord
# Token của tài khoản Discord (selfbot). Lấy từ DevTools > Network > Authorization.
DISCORD_USER_TOKEN=your_discord_user_token_here

# ID của kênh Discord cần theo dõi. Click phải kênh > Copy Channel ID.
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# ID của role cần phát hiện khi bị tag. Click phải role > Copy Role ID.
DISCORD_ROLE_ID=your_discord_role_id_here

# Telegram
# Token của Telegram Bot. Tạo qua @BotFather trên Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ID của chat/group nhận cảnh báo. nhắn tin cho bot rồi truy cập https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates để lấy chat_id.
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Vonage (Nexmo)
# API Key và Secret từ dashboard Vonage: https://dashboard.nexmo.com/
VONAGE_API_KEY=your_vonage_api_key_here
VONAGE_API_SECRET=your_vonage_api_secret_here

# Application ID từ Vonage Applications. Tạo app tại https://dashboard.nexmo.com/applications.
VONAGE_APPLICATION_ID=your_vonage_application_id_here

# Đường dẫn tới file private key (.key) tải về khi tạo Vonage Application.
VONAGE_PRIVATE_KEY_PATH=./private.key

# Số điện thoại Vonage đã mua và gán vào Application. Không dùng dấu +. Ví dụ: 12345678901
VONAGE_FROM_NUMBER=your_vonage_phone_number_here

# Số điện thoại cá nhân nhận cuộc gọi khẩn cấp. Có mã quốc gia, không dấu +. Ví dụ: 84901234567
MY_PHONE_NUMBER=your_phone_number_here
